// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  Bank       Bank[]
  Tournament Tournament[]

  @@map("users")
}

model Bank {
  id              String @id @default(uuid()) @db.Uuid
  userId          String @map("user_id") @db.Uuid
  bank            Float
  totalDeposit    Float  @map("total_deposit")
  totalWithdrawal Float  @map("total_withdrawal")
  profit          Float

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Tournament  Tournament[]
  deposits    Deposit[]
  withdrawals Withdrawal[]

  @@map("banks")
}

model Deposit {
  id     String   @id @default(uuid()) @db.Uuid
  bankId String   @map("bank_id") @db.Uuid
  amount Float
  date   DateTime

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("deposits")
}

model Withdrawal {
  id     String   @id @default(uuid()) @db.Uuid
  bankId String   @map("bank_id") @db.Uuid
  amount Float
  date   DateTime

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

model Tournament {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  bankId   String   @map("bank_id") @db.Uuid
  name     String
  platform String
  buyIn    Float
  currency String
  result   String
  profit   Float
  date     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}
