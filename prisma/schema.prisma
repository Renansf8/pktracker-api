// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  email    String @unique
  password String

  Bank                   Bank[]
  Tournament             Tournament[]
  TournamentSchedule     TournamentSchedule[]
  TournamentScheduleItem TournamentScheduleItem[]

  @@map("users")
}

model Bank {
  id              String @id @default(uuid()) @db.Uuid
  userId          String @map("user_id") @db.Uuid
  bank            Float
  totalDeposit    Float  @map("total_deposit")
  totalWithdrawal Float  @map("total_withdrawal")
  totalRake       Float  @default(0) @map("total_rake")
  profit          Float

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Tournament  Tournament[]
  deposits    Deposit[]
  withdrawals Withdrawal[]
  rakes       Rake[]

  @@map("banks")
}

model Deposit {
  id     String   @id @default(uuid()) @db.Uuid
  bankId String   @map("bank_id") @db.Uuid
  amount Float
  date   DateTime

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("deposits")
}

model Withdrawal {
  id     String   @id @default(uuid()) @db.Uuid
  bankId String   @map("bank_id") @db.Uuid
  amount Float
  date   DateTime

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

model Rake {
  id       String   @id @default(uuid()) @db.Uuid
  bankId   String   @map("bank_id") @db.Uuid
  amount   Float
  platform String?
  date     DateTime

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("rakes")
}

model Tournament {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  bankId   String   @map("bank_id") @db.Uuid
  name     String
  platform String
  buyIn    String
  currency String
  result   String?
  profit   Float    @default(0)
  itm      Boolean  @default(false)
  hasFt         Boolean  @default(false) @map("has_ft")
  hasSecondDay  Boolean  @default(false) @map("has_second_day")
  position      Int?
  date     DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

enum ScheduleType {
  WEEKLY
  SUNDAY
}

model TournamentSchedule {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  name      String
  type      ScheduleType
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items TournamentScheduleItem[]

  @@map("tournament_schedules")
}

model TournamentScheduleItem {
  id         String   @id @default(uuid()) @db.Uuid
  scheduleId String   @map("schedule_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String
  platform   String
  buyIn      Float
  currency   String
  time       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  schedule TournamentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tournament_schedule_items")
}
